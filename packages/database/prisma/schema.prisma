// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String
  emailVerified    Boolean  @default(false)
  creditsRemaining Int      @default(0)
  image            String?
  imageHash        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sessions               Session[]
  accounts               Account[]
  members                Member[]
  invitations            Invitation[]
  apikeys                Apikey[]
  oauthApplications      OauthApplication[]
  oauthAccessTokens      OauthAccessToken[]
  oauthConsents          OauthConsent[]
  oidcUserGrants         OidcUserGrant[]
  creditLedgerEntries    CreditLedgerEntry[]
  agents                 Agent[]
  agentActivityEvents    AgentActivityEvent[]
  inboxAgentReferences   InboxAgentReference[]
  integrationConnections IntegrationConnection[]
  veridianCredentials    VeridianCredential[]

  // Additional fields
  termsAccepted       Boolean @default(false)
  marketingOptIn      Boolean @default(false)
  onboardingCompleted Boolean @default(false)
  stripeCustomerId    String?
  twoFactorEnabled    Boolean @default(false)

  // KYC verification (one-to-one)
  kycVerificationId String?          @unique
  kycVerification   KycVerification? @relation(fields: [kycVerificationId], references: [id], onDelete: SetNull)

  // New domain relations
  createdOrgApiKeys       OrgApiKey[]
  kycSubmissions          KycSubmission[]
  walletCaches            WalletCache[]
  x402EvmWallets          X402EvmWallet[]
  x402Networks            X402Network[]
  x402BudgetsCreated      X402WalletBudget[]  @relation("X402WalletBudgetCreatedBy")
  x402PaymentAttempts     X402PaymentAttempt[]

  // Payment node: API key for this user (encrypted, server-side only; created on signup)
  paymentNodeApiKeyEncrypted String?

  // Two-factor authentication
  twoFactor TwoFactor?

  // Admin fields (Better Auth admin plugin)
  role       String    @default("user")
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  @@unique([email])
  @@unique([stripeCustomerId])
  @@map("user")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("twoFactor")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  activeOrganizationId String?
  activeOrganization   Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  impersonatedBy String?

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             Member[]
  invitations         Invitation[]
  sessions            Session[]
  veridianCredentials VeridianCredential[]

  stripeCustomerId String?
  invoiceEmail     String?

  // KYB fields
  kybVerificationId String?          @unique
  kybVerification   KybVerification? @relation(fields: [kybVerificationId], references: [id], onDelete: SetNull)

  // Domain relations
  agents                 Agent[]
  orgApiKeys             OrgApiKey[]
  kybSubmissions         KybSubmission[]
  integrationConnections IntegrationConnection[]
  x402EvmWallets         X402EvmWallet[]
  x402Networks           X402Network[]

  @@unique([slug])
  @@unique([stripeCustomerId])
  @@map("organization")
}

model KybVerification {
  id                String             @id @default(cuid())
  status            VerificationStatus @default(PENDING)
  sumsubApplicantId String?
  completedAt       DateTime?
  rejectionReason   String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  organization      Organization?
  submissions       KybSubmission[]

  @@index([sumsubApplicantId])
  @@map("kyb_verification")
}

model Member {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  @@unique([userId, organizationId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  inviter        User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("invitation")
}

model Apikey {
  id                  String    @id
  name                String?
  start               String?
  prefix              String?
  key                 String
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?
  rateLimitEnabled    Boolean?
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  permissions         String? // Better Auth apiKey plugin (v1.4+)
  metadata            String? // Better Auth apiKey plugin (enableMetadata: true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("apikey")
}

model OauthApplication {
  id           String   @id @default(cuid())
  clientId     String   @unique
  clientSecret String?
  type         String
  name         String
  icon         String?
  metadata     String?  @db.Text
  redirectUrls String   @db.Text
  disabled     Boolean  @default(false)
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("oauthApplication")
}

model OauthAccessToken {
  id                    String   @id @default(cuid())
  accessToken           String   @unique
  refreshToken          String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  oidcSessionId         String?
  clientId              String
  userId                String?
  user                  User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes                String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthAccessToken")
}

model OauthConsent {
  id           String   @id @default(cuid())
  clientId     String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes       String   @db.Text
  consentGiven Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
  @@index([userId])
  @@map("oauthConsent")
}

model OidcUserGrant {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String
  scopes    String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, clientId])
  @@index([clientId])
  @@index([userId])
  @@map("oidcUserGrant")
}

model CreditLedgerEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta        Int
  balanceAfter Int
  reason       String
  reference    String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@unique([userId, reason, reference])
  @@index([userId, createdAt])
  @@map("credit_ledger_entry")
}

model DeviceCode {
  id              String    @id @default(cuid())
  deviceCode      String    @unique
  userCode        String    @unique
  userId          String?
  expiresAt       DateTime
  status          String
  lastPolledAt    DateTime?
  pollingInterval Int?
  clientId        String?
  scope           String?

  @@index([userId])
  @@index([clientId])
  @@map("deviceCode")
}

model Jwks {
  id         String    @id @default(cuid())
  publicKey  String    @db.Text
  privateKey String    @db.Text
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@map("jwks")
}

model RateLimit {
  id          String  @id
  key         String?
  count       Int?
  lastRequest BigInt?

  @@map("rateLimit")
}

/// Tracks how many auth emails (magic-link + verification codes) have been
/// sent to a specific email address within a rolling window. Used to cap
/// sends at 5 per 30 minutes; the row is cleared on successful magic-link
/// code verification or when the user's email is verified.
model EmailSendRateLimit {
  id          String   @id @default(cuid())
  email       String   @unique
  count       Int      @default(0)
  windowStart DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("email_send_rate_limit")
}

model KycVerification {
  id                String             @id @default(uuid())
  status            VerificationStatus @default(PENDING)
  sumsubApplicantId String?
  completedAt       DateTime?
  rejectionReason   String?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User?
  submissions       KycSubmission[]

  @@index([status])
  @@index([sumsubApplicantId])
  @@map("kyc_verification")
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REVIEW
  VERIFIED
  REVOKED
  EXPIRED
}

enum RegistrationState {
  RegistrationRequested
  RegistrationInitiated
  RegistrationConfirmed
  RegistrationFailed
  DeregistrationRequested
  DeregistrationInitiated
  DeregistrationConfirmed
  DeregistrationFailed
}

enum AgentRuntimeProvider {
  DIRECT_MIP
  LANGDOCK
}

enum IntegrationProvider {
  LANGDOCK
}

enum MipJobStatus {
  AWAITING_PAYMENT
  RUNNING
  AWAITING_INPUT
  COMPLETED
  FAILED
}

model Agent {
  id                  String  @id @default(cuid())
  name                String
  description         String? // Short tagline, max 250 chars
  extendedDescription String? // Optional detailed overview (Markdown supported)
  apiUrl              String
  userId              String
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Organization ownership (optional; set when agent is created under an active org)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Registration
  registrationState RegistrationState @default(RegistrationConfirmed)

  // Runtime provider
  runtimeProvider         AgentRuntimeProvider   @default(DIRECT_MIP)
  integrationConnectionId String?
  integrationConnection   IntegrationConnection? @relation(fields: [integrationConnectionId], references: [id], onDelete: SetNull)
  providerConfig          Json?

  // Verification
  verificationStatus               VerificationStatus?  @default(PENDING)
  veridianCredentialId             String? // Credential ID from Veridian API
  veridianCredentials              VeridianCredential[] // Credentials issued for this agent
  verificationChallenge            String? // Masumi-generated challenge for agent endpoint verification
  verificationChallengeGeneratedAt DateTime? // When the challenge was generated
  verificationSecret               String? // Secret for HMAC - agent must prove it has this (stored in env)

  // Metadata
  tags     String[] @default([])
  metadata String? // JSON string for additional data
  icon     String? // Preset key (e.g. "bot", "sparkles") or URL for custom icon

  // Registry / pricing
  agentIdentifier   String? // On-chain or registry identifier
  networkIdentifier String? // Network this agent is registered on (e.g. Preprod, Mainnet)
  pricing           Json? // { pricingType: "Free"|"Fixed", prices: [{ amount: string, currency?: string }] } - amounts in USD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Domain relations
  agentReference          AgentReference?
  activityEvents          AgentActivityEvent[]
  mipJobs                 MipJob[]
  supportedPaymentSources SupportedPaymentSource[]
  x402PaymentAttempts     X402PaymentAttempt[]

  @@index([userId])
  @@index([organizationId])
  @@index([runtimeProvider])
  @@index([integrationConnectionId])
  @@index([verificationStatus])
  @@index([registrationState])
  @@index([networkIdentifier])
  @@map("agent")
}

model IntegrationConnection {
  id              String              @id @default(cuid())
  provider        IntegrationProvider
  name            String
  encryptedSecret String              @db.Text
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  metadata        Json?
  agents          Agent[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId, provider])
  @@index([organizationId, provider])
  @@map("integration_connection")
}

model MipJob {
  id                        String       @id @default(cuid())
  agentId                   String
  agent                     Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  status                    MipJobStatus @default(AWAITING_PAYMENT)
  identifierFromPurchaser   String
  inputData                 Json
  inputHash                 String
  inputSchema               Json?
  outputHash                String?
  result                    String?      @db.Text
  blockchainIdentifier      String?
  agentIdentifier           String?
  sellerVKey                String?
  payByTime                 DateTime?
  submitResultTime          DateTime?
  unlockTime                DateTime?
  externalDisputeUnlockTime DateTime?
  conversation              Json?
  error                     String?      @db.Text
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@index([agentId, status])
  @@index([blockchainIdentifier])
  @@map("mip_job")
}

/// Audit log of agent lifecycle events for the Activity feed.
/// Emitted when registration state changes, verification, deregister, or delete.
/// agentId is optional so AgentDeleted events survive when the agent row is removed (onDelete: SetNull).
/// agentNameSnapshot preserves display name after agentId is cleared on delete.
/// networkIdentifier scopes orphan events (agentId null) to Mainnet vs Preprod.
model AgentActivityEvent {
  id                String                 @id @default(cuid())
  userId            String
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId           String?
  agent             Agent?                 @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentNameSnapshot String?
  networkIdentifier String?
  type              AgentActivityEventType
  createdAt         DateTime               @default(now())

  @@index([userId])
  @@index([agentId])
  @@index([createdAt])
  @@index([type])
  @@index([networkIdentifier])
  @@map("agent_activity_event")
}

enum AgentActivityEventType {
  RegistrationInitiated
  RegistrationConfirmed
  RegistrationFailed
  DeregistrationRequested
  DeregistrationConfirmed
  AgentVerified
  AgentDeleted
}

// ─── New Domain Entity Models ─────────────────────────────────────────────────

/// Organization-scoped API keys for programmatic access to the platform.
///
/// NOTE: This is intentionally named OrgApiKey (not ApiKey) to avoid a Prisma 7
/// codegen collision with Better Auth's built-in `Apikey` model (table: apikey).
/// These are completely different — Better Auth's Apikey is user-scoped and
/// manages authentication tokens. OrgApiKey is org-scoped, supports custom
/// scopes, and is meant for machine-to-machine / programmatic access.
/// DB table: api_key
model OrgApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique // Hashed full key — never store plaintext
  keyPrefix      String // First 8 chars shown in UI for identification
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  scopes              String[]             @default([]) // Valid: "agents:read", "agents:write", "billing:read", "billing:write", "members:read", "members:write"
  enabled             Boolean              @default(true)
  lastUsedAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  x402WalletBudgets   X402WalletBudget[]
  x402PaymentAttempts X402PaymentAttempt[]

  @@index([organizationId])
  @@index([createdById])
  @@index([organizationId, enabled, lastUsedAt]) // Compound: API key usage tracking
  @@map("api_key")
}

/// Tracks each individual KYC (Know Your Customer) document submission attempt
/// for a user via Sumsub. Provides an audit trail of all attempts.
///
/// Distinct from KycVerification — KycVerification holds the overall/current
/// status (one-to-one with User), while KycSubmission records every attempt
/// (one-to-many with User), enabling retry tracking and history.
model KycSubmission {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  kycVerificationId String
  kycVerification   KycVerification    @relation(fields: [kycVerificationId], references: [id], onDelete: Cascade)
  sumsubApplicantId String? // Sumsub applicant ID for this submission
  status            VerificationStatus @default(PENDING)
  submittedAt       DateTime? // Set explicitly when the user submits to Sumsub
  reviewedAt        DateTime?
  rejectionReason   String?
  metadata          Json? // Additional Sumsub response data
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([userId])
  @@index([kycVerificationId])
  @@index([status])
  @@index([userId, status, createdAt]) // Compound: verification status queries
  @@map("kyc_submission")
}

/// Tracks each individual KYB (Know Your Business) document submission attempt
/// for an organization via Sumsub. Provides an audit trail of all attempts.
///
/// Distinct from KybVerification — KybVerification holds the overall/current
/// status (one-to-one with Organization), while KybSubmission records every
/// attempt (one-to-many with Organization).
model KybSubmission {
  id                String             @id @default(cuid())
  organizationId    String
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kybVerificationId String
  kybVerification   KybVerification    @relation(fields: [kybVerificationId], references: [id], onDelete: Cascade)
  sumsubApplicantId String? // Sumsub applicant ID for this submission
  status            VerificationStatus @default(PENDING)
  submittedAt       DateTime? // Set explicitly when the org submits to Sumsub
  reviewedAt        DateTime?
  rejectionReason   String?
  metadata          Json? // Additional Sumsub response data
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([organizationId])
  @@index([kybVerificationId])
  @@index([status])
  @@index([organizationId, status, createdAt]) // Compound: verification status queries
  @@map("kyb_submission")
}

/// Caches wallet connection state and identifiers for a user.
/// Supports both Cardano wallets (identifier = wallet address) and
/// Veridian wallets (identifier = KERI AID).
///
/// The composite unique on (userId, walletType, identifier) ensures
/// each user can only have one cache entry per wallet address/AID,
/// while still supporting multiple wallets of different types.
model WalletCache {
  id              String                 @id @default(cuid())
  userId          String
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletType      WalletType // CARDANO or VERIDIAN
  identifier      String // Cardano: wallet address | Veridian: KERI AID
  label           String? // User-friendly wallet name/alias
  networkId       String? // e.g. "mainnet", "preprod", "preview"
  connectionState WalletConnectionState? // Current wallet connection status
  metadata        Json? // Balance, staking info, or other wallet data
  lastSyncedAt    DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@unique([userId, walletType, identifier])
  @@index([userId])
  @@map("wallet_cache")
}

/// Links a local Agent to its entry in the external Masumi decentralized
/// registry. One-to-one with Agent — an agent may or may not have a
/// registry entry yet (status: "pending" until registered).
///
/// Stores the external registry URL, network identifier, payment node wallet
/// vkeys (we do not store mnemonic or address), and any metadata needed to
/// look up or verify the agent in the Masumi network.
model AgentReference {
  id                String               @id @default(cuid())
  agentId           String               @unique
  agent             Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  registryUrl       String? // URL of the agent's entry in the Masumi registry
  externalId        String? // Payment node registry request id (cuid)
  networkIdentifier String? // Masumi network identifier (e.g. Preprod, Mainnet)
  sellingWalletVkey String? // Payment node selling wallet vkey (store only vkey, not mnemonic/address)
  sellingWalletId   String? // Payment node internal wallet ID (for GET /wallet/ status checks)
  buyingWalletVkey  String? // Payment node buying wallet vkey (store only vkey)
  registeredAt      DateTime?
  lastVerifiedAt    DateTime?
  status            AgentReferenceStatus @default(PENDING)
  metadata          Json? // Additional registry data
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([externalId])
  @@index([networkIdentifier])
  @@map("agent_reference")
}

/// Links a user to inbox-agent registrations created through the SaaS layer.
///
/// Inbox registrations mint their on-chain token into a shared executing wallet,
/// so user payment-node wallet scopes cannot be used as the source of ownership.
/// This table is the local ownership record used by inbox list/manage routes.
model InboxAgentReference {
  id                     String            @id @default(cuid())
  userId                 String
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentNodeId          String
  networkIdentifier      String
  name                   String
  description            String?
  agentSlug              String
  state                  RegistrationState @default(RegistrationRequested)
  agentIdentifier        String?
  executingWalletId      String
  executingWalletVkey    String
  executingWalletAddress String
  smartContractAddress   String?
  registryEntry          Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@unique([networkIdentifier, paymentNodeId])
  @@index([userId, networkIdentifier])
  @@index([userId, networkIdentifier, state])
  @@index([paymentNodeId])
  @@index([agentIdentifier])
  @@map("inbox_agent_reference")
}

model VeridianCredential {
  id             String           @id @default(uuid())
  credentialId   String // Credential ID from Veridian API (SAID)
  schemaSaid     String // Schema SAID used for this credential
  aid            String // KERI identifier (AID) the credential was issued to
  status         CredentialStatus @default(ISSUED)
  credentialData String?          @db.Text // JSON string of full credential data
  attributes     String?          @db.Text // JSON string of credential attributes

  // Relationships
  userId         String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  agentId        String?
  agent          Agent?        @relation(fields: [agentId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Timestamps
  issuedAt  DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([agentId])
  @@index([organizationId])
  @@index([aid])
  @@index([schemaSaid])
  @@index([status])
  @@index([credentialId])
  @@map("veridian_credential")
}

// ─── x402 EVM payment rail (ported from masumi-payment-service; user/org scoped) ─

/// Advertised payment option on an agent (Cardano escrow and/or EVM x402 Exact).
model SupportedPaymentSource {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  chain   String
  network String
  /// Cardano escrow rows set paymentSourceType + address; EVM x402 rows leave null.
  paymentSourceType String?
  address           String
  scheme            X402PaymentScheme?
  asset             String?
  amount            BigInt?
  decimals          Int?
  payTo             String?
  resource          String?
  extra             Json?

  x402PaymentAttempts X402PaymentAttempt[]

  @@index([address])
  @@index([paymentSourceType])
  @@index([chain, network])
  @@index([agentId])
  @@map("supported_payment_source")
}

model X402Network {
  id                  String         @id @default(cuid())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  userId              String
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId      String?
  organization        Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  caip2Id             String
  displayName         String
  rpcUrl              String
  isTestnet           Boolean        @default(false)
  isEnabled           Boolean        @default(true)
  defaultAsset        String?
  facilitatorWalletId String?
  createdByUserId     String?
  FacilitatorWallet   X402EvmWallet? @relation("X402NetworkFacilitatorWallet", fields: [facilitatorWalletId], references: [id], onDelete: SetNull)
  WalletBudgets       X402WalletBudget[]
  PaymentAttempts     X402PaymentAttempt[]

  @@unique([userId, caip2Id])
  @@index([isEnabled])
  @@index([userId])
  @@index([organizationId])
  @@map("x402_network")
}

model X402EvmWallet {
  id                  String                        @id @default(cuid())
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  userId              String
  user                User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId      String?
  organization        Organization?                 @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  address             String
  type                X402EvmWalletType
  encryptedPrivateKey String                        @db.Text
  note                String?
  deletedAt           DateTime?
  createdByUserId     String?
  FacilitatesNetworks X402Network[]                 @relation("X402NetworkFacilitatorWallet")
  Budgets             X402WalletBudget[]
  PaymentAttempts     X402PaymentAttempt[]
  LowBalanceRules     X402EvmWalletLowBalanceRule[]

  @@unique([address])
  @@index([deletedAt])
  @@index([userId])
  @@index([organizationId])
  @@index([type])
  @@map("x402_evm_wallet")
}

model X402EvmWalletLowBalanceRule {
  id              String           @id @default(cuid())
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  evmWalletId     String
  caip2Network    String
  asset           String
  thresholdAmount BigInt
  enabled         Boolean          @default(true)
  status          LowBalanceStatus @default(Unknown)
  lastKnownAmount BigInt?
  lastCheckedAt   DateTime?
  lastAlertedAt   DateTime?
  EvmWallet       X402EvmWallet    @relation(fields: [evmWalletId], references: [id], onDelete: Cascade)

  @@unique([evmWalletId, caip2Network, asset])
  @@index([evmWalletId, enabled])
  @@index([enabled, status])
  @@map("x402_evm_wallet_low_balance_rule")
}

model X402WalletBudget {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  orgApiKeyId     String
  orgApiKey       OrgApiKey     @relation(fields: [orgApiKeyId], references: [id], onDelete: Cascade)
  evmWalletId     String
  caip2Network    String
  asset           String
  remainingAmount BigInt
  spentAmount     BigInt        @default(0)
  enabled         Boolean       @default(true)
  createdByUserId String?
  CreatedByUser   User?         @relation("X402WalletBudgetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  EvmWallet       X402EvmWallet @relation(fields: [evmWalletId], references: [id], onDelete: Cascade)
  Network         X402Network   @relation(fields: [userId, caip2Network], references: [userId, caip2Id], onDelete: Restrict)

  @@unique([orgApiKeyId, evmWalletId, caip2Network, asset])
  @@index([orgApiKeyId, enabled])
  @@index([evmWalletId, enabled])
  @@index([caip2Network, asset])
  @@index([createdByUserId])
  @@index([userId])
  @@map("x402_wallet_budget")
}

model X402PaymentAttempt {
  id                       String                  @id @default(cuid())
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  direction                X402PaymentDirection
  status                   X402PaymentStatus
  userId                   String
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgApiKeyId              String?
  orgApiKey                OrgApiKey?              @relation(fields: [orgApiKeyId], references: [id], onDelete: SetNull)
  evmWalletId              String?
  agentId                  String?
  supportedPaymentSourceId String?
  caip2Network             String
  scheme                   X402PaymentScheme       @default(Exact)
  asset                    String
  amount                   BigInt
  payTo                    String
  payer                    String?
  resource                 String?
  paymentPayloadHash       String?
  paymentPayload           Json?
  paymentIdentifier        String?
  errorReason              String?
  errorMessage             String?
  EvmWallet                X402EvmWallet?          @relation(fields: [evmWalletId], references: [id], onDelete: SetNull)
  Agent                    Agent?                  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  SupportedPaymentSource   SupportedPaymentSource? @relation(fields: [supportedPaymentSourceId], references: [id], onDelete: SetNull)
  Network                  X402Network             @relation(fields: [userId, caip2Network], references: [userId, caip2Id], onDelete: Restrict)
  Settlement               X402Settlement?

  @@index([userId, createdAt])
  @@index([orgApiKeyId, createdAt])
  @@index([agentId, createdAt])
  @@index([supportedPaymentSourceId])
  @@index([paymentIdentifier])
  @@index([caip2Network, asset])
  @@index([status, createdAt])
  @@map("x402_payment_attempt")
}

model X402Settlement {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  paymentAttemptId   String             @unique
  paymentPayloadHash String             @unique
  success            Boolean
  txHash             String?
  caip2Network       String
  amount             BigInt?
  payer              String?
  rawResponse        Json?
  PaymentAttempt     X402PaymentAttempt @relation(fields: [paymentAttemptId], references: [id], onDelete: Cascade)

  @@index([txHash])
  @@index([caip2Network])
  @@map("x402_settlement")
}

enum CredentialStatus {
  PENDING
  ISSUED
  REVOKED
  EXPIRED
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum WalletType {
  CARDANO
  VERIDIAN
}

/// Connection status of a cached wallet.
enum WalletConnectionState {
  CONNECTED // Wallet is actively connected
  DISCONNECTED // Wallet was previously connected but is now disconnected
}

/// Status of an agent's registration in the Masumi decentralized registry.
enum AgentReferenceStatus {
  PENDING // Registered locally, not yet submitted to the network registry
  ACTIVE // Live and discoverable in the registry
  INACTIVE // Temporarily disabled in the registry
  DEREGISTERED // Permanently removed from the registry
}

enum X402EvmWalletType {
  Purchasing
  Selling
}

enum X402PaymentScheme {
  Exact
}

enum X402PaymentDirection {
  InboundVerify
  InboundSettle
  OutboundPayment
}

enum X402PaymentStatus {
  PaymentRequired
  Verified
  Settled
  Failed
  Replayed
}

enum LowBalanceStatus {
  Unknown
  Healthy
  Low
}
