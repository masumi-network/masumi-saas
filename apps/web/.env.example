# Database
DATABASE_URL="postgresql://user:password@localhost:5432/masumi_saas?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-change-this-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# OAuth (Optional - for social sign-in)
# Redirect URIs: {BETTER_AUTH_URL}/api/auth/callback/{provider}
# Google: Google Cloud Console | GitHub: GitHub Developer Settings
# Microsoft: Microsoft Entra ID | Apple: Apple Developer Portal (requires JWT client secret)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Server-side API calls (optional - falls back to request headers if not set)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sokosumi marketplace URL (optional - defaults to https://app.sokosumi.com)
NEXT_PUBLIC_SOKOSUMI_MARKETPLACE_URL="https://app.sokosumi.com"

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_PROJECT="masumi-saas"

# Postmark (Optional - for email sending)
# If not set, emails will be logged to console in development
POSTMARK_SERVER_ID=""
POSTMARK_FROM_EMAIL="noreply@sokosumi.com"

# API Rate Limiting
API_RATE_LIMIT_TIME_WINDOW="60"
API_RATE_LIMIT_MAX_REQUESTS="100"


PUBLIC_API_RATE_LIMIT_WINDOW="60000"
PUBLIC_API_RATE_LIMIT_MAX="60"

CORS_ALLOWED_ORIGINS="http://localhost:3000"

# Organization Settings
ORGANIZATION_INVITATION_LIMIT="100"
ORGANIZATION_LIMIT="10"
ORGANIZATION_INVITATION_EXPIRES_IN_DAYS="7"

# Email Verification
# When "true", users must verify their email to sign in and create organizations
REQUIRE_EMAIL_VERIFICATION="false"
EMAIL_VERIFICATION_EXPIRES_IN_DAYS="7"

# Veridian Credential Server (Required)
VERIDIAN_CREDENTIAL_SERVER_URL="https://cred-issuance.masumi-identity.xyz"
VERIDIAN_KERIA_URL="https://keria.masumi-identity.xyz"

# Sumsub (Optional - for KYC/KYB verification)
SUMSUB_APP_TOKEN=""
SUMSUB_SECRET_KEY=""
SUMSUB_BASE_URL="https://api.sumsub.com"
SUMSUB_KYC_LEVEL="id-only"
SUMSUB_KYB_LEVEL="id-only"

# Veridian Agent Verification Schema (Required for agent verification)
# Masumi schema (generated via credential-schema-builder): scripts/schemas/masumi-agent-verification.json
# To regenerate: start credential-schema-builder backend then run pnpm create:agent-verification-schema
VERIDIAN_AGENT_VERIFICATION_SCHEMA_SAID="EBV88FehFeDa1tiFUQxuuVi1QXKOXVpwOc1cdFMCzBlI"

# Admin Configuration
# Comma-separated user IDs that always have admin access (bootstrap mechanism)
# This is auto-managed by the admin CLI. To set up your first admin:
#   1. Sign up normally at /signup
#   2. Run: pnpm admin:promote your@email.com
# Other commands: pnpm admin:demote, pnpm admin:list
ADMIN_USER_IDS=""

# Payment Node (Masumi Payment Service)
# Base URL: https://payment.masumi.network/api/v1 or http://localhost:3001/api/v1 for local
PAYMENT_NODE_BASE_URL="https://payment.masumi.network/api/v1"
# Admin API key (for adding wallets and creating per-user API keys). Never expose to the client.
PAYMENT_NODE_ADMIN_API_KEY=""
# Single shared payment source id (for PATCH add-wallets). From payment node admin.
PAYMENT_NODE_PAYMENT_SOURCE_ID=""
# Encryption key for storing per-user payment node API keys (min 32 chars recommended; HKDF)
PAYMENT_NODE_ENCRYPTION_KEY=""
# Optional. Per-deployment salt for key derivation; set to a unique value per environment to avoid key reuse.
# After setting, run: pnpm --filter web run re-encrypt-payment-node-secrets
# PAYMENT_NODE_KEY_SALT=""
