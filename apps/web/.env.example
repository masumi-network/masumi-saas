# Database
DATABASE_URL="postgresql://user:password@localhost:5432/masumi_saas?schema=public"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-change-this-in-production"
BETTER_AUTH_URL="http://localhost:2999"
# Public OIDC issuer URL (optional; defaults to BETTER_AUTH_URL)
# OIDC_PUBLIC_ISSUER_URL="http://localhost:2999"
# Trusted first-party OIDC clients for external webapp / CLI
# Webapp callback defaults to http://localhost:3002/auth/callback (separate port from this app on 2999)
# The Spacetime bridge also allows the configured web redirect origins for CORS.
# OIDC_WEB_CLIENT_ID="masumi-spacetime-web"
# OIDC_WEB_CLIENT_NAME="Masumi Web App"
# OIDC_WEB_REDIRECT_URLS="http://localhost:3002/auth/callback"
# CLI callback defaults to a local loopback URL used only for client registration / audience checks
# OIDC_CLI_CLIENT_ID="masumi-spacetime-cli"
# OIDC_CLI_CLIENT_NAME="Masumi CLI"
# OIDC_CLI_REDIRECT_URLS="http://127.0.0.1:43110/callback"
# Device verification page shown during the CLI device login flow
# OIDC_DEVICE_VERIFICATION_URI="/device"
# Magic link (better-auth): rate limit on POST /sign-in/magic-link and GET /magic-link/verify
# MAGIC_LINK_EXPIRES_IN_MINUTES="15"
# MAGIC_LINK_RATE_LIMIT_WINDOW="60"
# MAGIC_LINK_RATE_LIMIT_MAX="3"
# Deprecated alias for MAGIC_LINK_RATE_LIMIT_MAX only (same value):
# MAGIC_LINK_ALLOWED_ATTEMPTS="3"

# Next.js Server Actions (required for multi-instance deployments e.g. DigitalOcean)
# Base64-encoded AES key (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be set at build time. Prevents "Failed to find Server Action" on deploy.
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=""

# OAuth (Optional - for social sign-in)
# Redirect URIs: {BETTER_AUTH_URL}/api/auth/callback/{provider}
# Google: Google Cloud Console | GitHub: GitHub Developer Settings
# Microsoft: Microsoft Entra ID
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Server-side API calls (optional - falls back to request headers if not set)
NEXT_PUBLIC_APP_URL="http://localhost:2999"

# Sokosumi marketplace URL (optional - defaults to https://app.sokosumi.com)
NEXT_PUBLIC_SOKOSUMI_MARKETPLACE_URL="https://app.sokosumi.com"

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_PROJECT="masumi-saas"

# Postmark (Optional - for email sending)
# If not set, emails will be logged to console in development
POSTMARK_SERVER_ID=""
POSTMARK_FROM_EMAIL="noreply@sokosumi.com"
# Optional: logo image URL for transactional emails (verification, magic link, invitations, etc.)
# EMAIL_BRAND_LOGO_URL="https://avatars.githubusercontent.com/u/194367856?s=200&v=4"
# Optional: privacy policy URL (signup forms + magic link email consent line; default is the House of Communication policy)
# NEXT_PUBLIC_PRIVACY_POLICY_URL="https://www.house-of-communication.com/de/en/footer/privacy-policy.html"

# API Rate Limiting
API_RATE_LIMIT_TIME_WINDOW="60"
API_RATE_LIMIT_MAX_REQUESTS="100"


PUBLIC_API_RATE_LIMIT_WINDOW="60000"
PUBLIC_API_RATE_LIMIT_MAX="60"

# GET /api/health — limits outbound payment-service pings (per IP when x-forwarded-for / x-real-ip is set)
HEALTH_RATE_LIMIT_WINDOW_MS="60000"
HEALTH_RATE_LIMIT_MAX="30"
# Shared bucket when client IP is unknown (e.g. probes without X-Forwarded-For)
HEALTH_RATE_LIMIT_MAX_UNIDENTIFIED="300"
# Timeout (ms) for the payment-node liveness GET during /api/health. Default 5000.
# PAYMENT_NODE_HEALTH_TIMEOUT_MS="5000"
# Optional full URL for that liveness check. When unset, URL is derived from PAYMENT_NODE_BASE_URL
# (Masumi payment service: …/api/v1/health). Set if your ingress only exposes https://host/health.
# PAYMENT_NODE_HEALTH_URL="https://payment.masumi.network/health"

# General API CORS allowlist. The OIDC Spacetime bridge also accepts origins
# derived from OIDC_WEB_REDIRECT_URLS without needing them duplicated here.
CORS_ALLOWED_ORIGINS="http://localhost:2999"

# Organization Settings
ORGANIZATION_INVITATION_LIMIT="100"
ORGANIZATION_LIMIT="10"
ORGANIZATION_INVITATION_EXPIRES_IN_DAYS="7"

# Email Verification
# When "true", users must verify their email to sign in, create organizations, and access app routes/API.
# Unverified users are redirected to /account (verify banner) and API routes return 403.
# Invitation flows (get/accept/reject) remain accessible to unverified users.
REQUIRE_EMAIL_VERIFICATION="false"
EMAIL_VERIFICATION_EXPIRES_IN_DAYS="7"

# Veridian Credential Server (Required)
VERIDIAN_CREDENTIAL_SERVER_URL="https://cred-issuance.masumi-identity.xyz"
VERIDIAN_KERIA_URL="https://keria.masumi-identity.xyz"
# Public KERIA URLs shown in the Veridian wallet setup UI.
# `NEXT_PUBLIC_*` is inlined into the browser bundle — restart dev after changing.
NEXT_PUBLIC_VERIDIAN_KERIA_CONNECT_URL="https://keria.masumi-identity.xyz"
NEXT_PUBLIC_VERIDIAN_KERIA_BOOT_URL="https://keria.masumi-identity.xyz"

# Sumsub (Optional - for KYC/KYB verification)
SUMSUB_APP_TOKEN=""
SUMSUB_SECRET_KEY=""
SUMSUB_BASE_URL="https://api.sumsub.com"
SUMSUB_KYC_LEVEL="id-only"
SUMSUB_KYB_LEVEL="id-only"

# Veridian Agent Verification Schema (Required for agent verification)
# Masumi schema (generated via credential-schema-builder): scripts/schemas/masumi-agent-verification.json
# To regenerate: start credential-schema-builder backend then run pnpm create:agent-verification-schema
VERIDIAN_AGENT_VERIFICATION_SCHEMA_SAID="EBV88FehFeDa1tiFUQxuuVi1QXKOXVpwOc1cdFMCzBlI"

# Masumi Identity SDK — Verifiable Credentials API reference (credential summary footer + verified shield tooltip link).
# `NEXT_PUBLIC_*` is inlined into the browser bundle — restart dev after changing.
NEXT_PUBLIC_VERIFIABLE_CREDENTIALS_SDK_DOC_URL="https://masumi-identity-sdk-docs-8lhm9.ondigitalocean.app/api-reference/credentials"

# Admin Configuration
# Comma-separated user IDs that always have admin access (bootstrap mechanism)
# This is auto-managed by the admin CLI. To set up your first admin:
#   1. Sign up normally at /signup
#   2. Run: pnpm admin:promote your@email.com
# Other commands: pnpm admin:demote, pnpm admin:list
ADMIN_USER_IDS=""

# Payment Node (Masumi Payment Service)
# Base URL: https://payment.masumi.network/api/v1.
# For local app-only dev you may point this at the SaaS proxy (http://localhost:2999/api/v1);
# startup validation will skip that self-referential proxy to avoid hanging boot.
PAYMENT_NODE_BASE_URL="https://payment.masumi.network/api/v1"
# See PAYMENT_NODE_HEALTH_TIMEOUT_MS and PAYMENT_NODE_HEALTH_URL under GET /api/health above.
# Admin API key (for adding wallets and creating per-user API keys). Never expose to the client.
PAYMENT_NODE_ADMIN_API_KEY=""
# Network-specific shared payment source ids (for PATCH add-wallets). From payment node admin.
PAYMENT_NODE_PAYMENT_SOURCE_ID_PREPROD=""
PAYMENT_NODE_PAYMENT_SOURCE_ID_MAINNET=""
# Comma-separated allowlist of existing managed selling wallet addresses used to pay
# for new agent registrations. One matching wallet is chosen at random per registration,
# and the newly created agent wallet receives the registry NFT.
PAYMENT_NODE_REGISTRATION_FUNDING_WALLETS_PREPROD=""
PAYMENT_NODE_REGISTRATION_FUNDING_WALLETS_MAINNET=""
# Optional: payment contract address (bech32) per source. Skips GET /payment-source when resolving filters / deregister fallback.
# PAYMENT_NODE_SMART_CONTRACT_ADDRESS_PREPROD="addr_test1..."
# PAYMENT_NODE_SMART_CONTRACT_ADDRESS_MAINNET="addr1..."
# Encryption key for storing per-user payment node API keys (min 32 chars recommended; HKDF)
PAYMENT_NODE_ENCRYPTION_KEY=""
# Optional. Per-deployment salt for key derivation; set to a unique value per environment to avoid key reuse.
# After setting, run: pnpm --filter web run re-encrypt-payment-node-secrets
# PAYMENT_NODE_KEY_SALT=""

# Registry Service (Masumi Registry Service)
# Base URL: https://registry.masumi.network/api/v1
REGISTRY_SERVICE_BASE_URL="https://registry.masumi.network/api/v1"
# Shared server-side API key for safe registry lookup proxy routes. Never expose to the client.
REGISTRY_SERVICE_API_KEY=""
# Optional override for fetching the upstream registry OpenAPI spec during codegen.
# REGISTRY_SERVICE_OPENAPI_URL="https://registry.masumi.network/api-docs"
