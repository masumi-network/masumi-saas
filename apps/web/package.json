{
  "name": "web",
  "version": "0.1.0",
  "engines": {
    "node": "24.x"
  },
  "private": true,
  "scripts": {
    "dev": "next dev -p 2999",
    "build": "next build",
    "start": "next start -p 2999",
    "lint": "node scripts/run-eslint.cjs --max-warnings 0 .",
    "lint:fix": "node scripts/run-eslint.cjs --fix .",
    "format": "prettier --log-level silent --write \"src/**/*.{ts,tsx}\"",
    "shadcn-add": "pnpm dlx shadcn-ui@latest add",
    "openapi:manifest": "node --experimental-strip-types src/lib/openapi/generate-route-contract-manifest.ts",
    "swagger-json": "pnpm run openapi:manifest && node --import tsx src/lib/swagger/cli.ts",
    "swagger:generate": "pnpm run swagger-json",
    "check-openapi-json": "pnpm run openapi:manifest && node --import tsx src/lib/swagger/verify-openapi-json-sync.ts",
    "payment-node:fetch-spec": "node scripts/fetch-payment-node-openapi.mjs",
    "payment-node:generate": "pnpm run payment-node:fetch-spec && openapi-typescript scripts/specs/payment-node-openapi.json -o src/lib/payment-node/generated/paths.d.ts",
    "payment-node:generate:local": "openapi-typescript scripts/specs/payment-node-openapi.json -o src/lib/payment-node/generated/paths.d.ts",
    "registry-service:fetch-spec": "node scripts/fetch-registry-service-openapi.mjs",
    "registry-service:generate": "pnpm run registry-service:fetch-spec && openapi-typescript scripts/specs/registry-service-openapi.json -o src/lib/registry-service/generated/paths.d.ts",
    "registry-service:generate:local": "openapi-typescript scripts/specs/registry-service-openapi.json -o src/lib/registry-service/generated/paths.d.ts",
    "re-encrypt-payment-node-secrets": "tsx scripts/re-encrypt-payment-node-secrets.ts",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "test:e2e": "vitest run tests/e2e",
    "test:stress": "vitest run tests/stress",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "8.4.0",
    "@cardano-foundation/cardano-connect-with-wallet": "0.2.15",
    "@cardano-foundation/cardano-connect-with-wallet-core": "0.2.8",
    "@fabianbormann/cardano-peer-connect": "1.2.18",
    "@hookform/resolvers": "5.2.2",
    "@masumi/database": "workspace:*",
    "@monaco-editor/react": "4.7.0",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tooltip": "1.2.8",
    "@react-email/components": "1.0.4",
    "@sentry/nextjs": "10.27.0",
    "@sumsub/websdk": "2.6.1",
    "@tanstack/react-query": "5.90.21",
    "@tiptap/extension-placeholder": "3.19.0",
    "@tiptap/pm": "3.19.0",
    "@tiptap/react": "3.19.0",
    "@tiptap/starter-kit": "3.19.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.36.2",
    "better-auth": "1.4.4",
    "better-auth-localization": "2.2.2",
    "canonical-json": "^0.4.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "geist": "1.7.0",
    "gravatar-url": "4.0.1",
    "lucide-react": "0.555.0",
    "lz-string": "1.5.0",
    "masumi-schema-validator-component": "1.2.0",
    "next": "16.0.6",
    "next-intl": "4.5.6",
    "next-themes": "0.4.6",
    "openapi-fetch": "0.17.0",
    "postmark": "4.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-email": "5.2.1",
    "react-hook-form": "7.67.0",
    "react-icons": "5.5.0",
    "react-markdown": "10.1.0",
    "react-qrcode-logo": "4.0.0",
    "react-social-login-buttons": "4.1.1",
    "remark-breaks": "4.0.0",
    "remark-gfm": "4.0.1",
    "sanitize-html": "2.17.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "swagger-ui-react": "5.31.0",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "1.0.7",
    "tw-animate-css": "1.4.0",
    "zod": "4.1.13",
    "zod-form-data": "3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.17",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "22.19.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.0",
    "@types/swagger-ui-react": "5.18.0",
    "@vitest/coverage-v8": "4.1.1",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "2.10.18",
    "cross-env": "10.1.0",
    "eslint": "8.57.1",
    "eslint-config-next": "16.0.6",
    "eslint-plugin-react": "7.37.5",
    "openapi-typescript": "7.13.0",
    "postcss": "8.4.38",
    "prettier": "3.7.3",
    "prettier-plugin-tailwindcss": "0.7.1",
    "tailwindcss": "4.1.18",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vitest": "4.1.1"
  }
}
